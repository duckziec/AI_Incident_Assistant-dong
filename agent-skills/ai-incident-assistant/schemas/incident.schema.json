{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/ai-incident-assistant/incident.schema.json",
  "title": "AI Incident Assistant Incident",
  "type": "object",
  "required": [
    "incident_id",
    "title",
    "description",
    "severity",
    "status",
    "impact_scope",
    "platform_sources",
    "sla",
    "created_at"
  ],
  "properties": {
    "incident_id": {
      "type": "string",
      "pattern": "^INC-[0-9]{8}-[0-9]{3,}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "component": {
      "type": ["string", "null"]
    },
    "severity": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low"]
    },
    "status": {
      "type": "string",
      "enum": ["Open", "In Progress", "Resolved", "Closed", "Cancelled"]
    },
    "impact_scope": {
      "type": "object",
      "required": ["groups_reported"],
      "properties": {
        "estimated_users": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "groups_reported": {
          "type": "integer",
          "minimum": 1
        },
        "impact_text": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": ["string", "null"],
      "enum": ["Production", "Staging", "Dev", null]
    },
    "steps_to_reproduce": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "jira_issue_key": {
      "type": ["string", "null"],
      "pattern": "^[A-Z][A-Z0-9]+-[0-9]+$"
    },
    "platform_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["platform", "group_id", "message_id", "sender_id", "timestamp"],
        "properties": {
          "platform": {
            "type": "string",
            "enum": ["telegram", "zalo"]
          },
          "group_id": {
            "type": "string"
          },
          "message_id": {
            "type": "string"
          },
          "sender_id": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    },
    "sla": {
      "type": "object",
      "required": ["deadline_minutes", "started_at", "breached"],
      "properties": {
        "deadline_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "first_response_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "breached": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "assigned_to": {
      "type": ["string", "null"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}

